# Deployed VotingFactory contract address
VITE_FACTORY_ADDRESS=0xeeaC52328177702d60841871B6aEa4Ff9169fa28

# Target chain id (Sepolia = 11155111, Holesky = 17000, mainnet = 1)
VITE_CHAIN_ID=11155111

# Human-readable chain name used in error messages
VITE_CHAIN_NAME=Sepolia

# Native currency symbol displayed in the UI
VITE_CURRENCY_SYMBOL=ETH

# Explorer URL prefix for transactions/addresses: "<prefix>/tx/<hash>"
VITE_EXPLORER_URL=https://sepolia.etherscan.io

# Reown (ex-WalletConnect) AppKit project id — REQUIRED for the wallet modal.
# Grab a free one at https://cloud.reown.com
VITE_REOWN_PROJECT_ID=
